{
    "name": "dashboard",
    "type": "module",
    "scripts": {
        "build": "pnpm db:generate && nuxt build",
        "dev": "pnpm db:generate && pnpm db:deploy && nuxt dev",
        "preview": "pnpm db:deploy && node --env-file-if-exists=.env -r ./scripts/fixPrisma.js .output/server/index.mjs",
        "postinstall": "nuxt prepare",
        "cleanup": "nuxt cleanup",
        "lint:types": "nuxt typecheck",
        "lint:code": "eslint --fix .",
        "lint": "pnpm lint:code",
        "check": "pnpm build && pnpm lint",
        "release": "changelogen --release",
        "db:prototype": "prisma db push",
        "db:migrate": "prisma migrate dev --create-only",
        "db:studio": "prisma studio",
        "db:generate": "prisma generate --no-hints",
        "db:deploy": "prisma migrate deploy",
        "db:reset": "prisma migrate reset"
    },
    "dependencies": {
        "@ffmpeg-installer/ffmpeg": "^1.1.0",
        "@fileship/telemetry": "workspace:*",
        "@huggingface/transformers": "^4.2.0",
        "@orama/orama": "^3.1.18",
        "@orama/stopwords": "^3.1.18",
        "@simplewebauthn/server": "^13.3.2",
        "argon2": "^0.44.0",
        "color": "^5.0.3",
        "consola": "^3.4.2",
        "defu": "^6.1.7",
        "dotenv": "^17.4.2",
        "engine.io": "^6.6.9",
        "filesize": "^11.0.17",
        "fluent-ffmpeg": "^2.1.3",
        "nanoid": "^5.1.16",
        "otplib": "^13.4.1",
        "pathe": "^2.0.3",
        "sharp": "^0.35.2",
        "socket.io": "^4.8.3",
        "stream-chain": "^4.2.5",
        "stream-json": "^3.4.0",
        "tar": "^7.5.17",
        "unocss": "^66.7.2",
        "uqr": "^0.1.3",
        "vue": "^3.5.39",
        "vue-router": "^5.1.0",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@iconify-json/heroicons": "^1.2.3",
        "@iconify-json/lucide": "^1.2.114",
        "@iconify-json/mdi": "^1.2.3",
        "@iconify-json/solar": "^1.2.5",
        "@nuxt/eslint": "^1.16.0",
        "@nuxt/fonts": "^0.14.0",
        "@nuxt/icon": "^2.2.4",
        "@nuxt/kit": "^4.4.8",
        "@nuxtjs/turnstile": "^1.1.3",
        "@prisma/adapter-pg": "^7.8.0",
        "@prisma/client": "^7.8.0",
        "@simplewebauthn/browser": "^13.3.0",
        "@simplewebauthn/types": "^12.0.0",
        "@types/fluent-ffmpeg": "^2.1.28",
        "@types/stream-chain": "^2.1.0",
        "@types/stream-json": "^1.7.8",
        "@unocss/eslint-config": "^66.7.2",
        "@unocss/nuxt": "^66.7.2",
        "@unocss/reset": "^66.7.2",
        "@vite-pwa/nuxt": "^1.1.1",
        "@vueuse/core": "^14.3.0",
        "@vueuse/nuxt": "^14.3.0",
        "apexcharts": "^5.15.2",
        "bufferutil": "^4.1.0",
        "changelogen": "^0.6.2",
        "dayjs": "^1.11.21",
        "eslint": "^10.5.0",
        "eslint-plugin-simple-import-sort": "^13.0.0",
        "gsap": "^3.15.0",
        "highlight.js": "^11.11.1",
        "katex": "^0.17.0",
        "marked": "^18.0.5",
        "marked-highlight": "^2.2.4",
        "marked-katex-extension": "^5.1.10",
        "nuxt": "^4.4.8",
        "prisma": "^7.8.0",
        "scule": "^1.3.0",
        "socket.io-client": "^4.8.3",
        "typescript": "^6.0.3",
        "unocss-preset-animations": "^1.3.0",
        "unocss-preset-scrollbar": "^4.0.0",
        "utf-8-validate": "^6.0.6",
        "vue-sonner": "^2.0.9",
        "vue-tsc": "^3.3.5",
        "vue3-apexcharts": "^1.11.1"
    },
    "packageManager": "pnpm@11.9.0"
}
